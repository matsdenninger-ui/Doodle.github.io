  <button class="tab-btn" onclick="showTab('supplements',event)">💊 Supplements</button>
  <button class="tab-btn" onclick="showTab('timing',event)">⏱ Timing</button>
  <button class="tab-btn" onclick="showTab('goals',event)">🎯 Ziele</button>
